# ---------------------------------------------------------------------------
# lms_project environment template.
# Copy this file to ".env" and fill in real values. Never commit ".env".
# ---------------------------------------------------------------------------

# Core Django
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Security and session settings
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCKOUT_SECONDS=300
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
X_FRAME_OPTIONS=DENY
USE_X_FORWARDED_PROTO=False

# Upload limits
MAX_VIDEO_UPLOAD_BYTES=2147483648
MAX_STUDY_MATERIAL_BYTES=52428800
MAX_PROFILE_IMAGE_BYTES=5242880

# Database (PostgreSQL). Leave blank to fall back to local SQLite.
# Example: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Cloudflare R2 (S3-compatible object storage)
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT_URL=

# Modal (serverless GPU)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
# Optional: set to False/0 if you want to use a real Redis + Celery worker even in DEBUG.
CELERY_TASK_ALWAYS_EAGER=True

# Pinecone vector store
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# LLM / speech providers
GROQ_API_KEY=
SARVAM_API_KEY=

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
