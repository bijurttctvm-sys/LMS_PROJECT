# ---------------------------------------------------------------------------
# lms_project environment template.
# Copy this file to ".env" and fill in real values. Never commit ".env".
# ---------------------------------------------------------------------------

# Core Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL). Leave blank to fall back to local SQLite.
# Example: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Cloudflare R2 (S3-compatible object storage)
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT_URL=

# Modal (serverless GPU)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
# Optional: set to False/0 if you want to use a real Redis + Celery worker even in DEBUG.
CELERY_TASK_ALWAYS_EAGER=True

# Pinecone vector store
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# LLM / speech providers
GROQ_API_KEY=
SARVAM_API_KEY=

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
